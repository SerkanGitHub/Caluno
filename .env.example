# Public Supabase project settings used by the web app.
# Safe to expose to the browser, but still environment-specific.
PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Local web origin used for auth redirects in development.
PUBLIC_SITE_URL=http://localhost:5174
